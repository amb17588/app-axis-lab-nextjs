# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# ─── Email (contact form — Resend) ────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 100 emails/day, 3 000/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address shown in the From field.
# On the free plan you can only send from onboarding@resend.dev until you verify
# your own domain. After verifying, use: AppAxisLab <hello@yourdomain.com>
RESEND_FROM=AppAxisLab <onboarding@resend.dev>

# Inbox that receives contact form submissions
RESEND_TO=taimoor@boltechsolutions.com
