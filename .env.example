# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# ─── SMTP (contact form email delivery) ──────────────────────────────────────
# Provider: Gmail, SendGrid, Resend, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                   # true for port 465 (SSL), false for 587 (STARTTLS)

# Sending account credentials
SMTP_USER=you@example.com
SMTP_PASS=your-app-password-here    # Gmail: use an App Password, not your account password

# Display name and address shown in the From field
SMTP_FROM=you@example.com
SMTP_FROM_NAME=AppAxisLab

# Inbox that receives contact form submissions
SMTP_TO=you@example.com
